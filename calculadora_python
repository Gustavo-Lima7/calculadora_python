import math
from colorama import Fore, Style #Biblioteca de cores para o terminal para colorir/personalizar o terminal.
from time import sleep #Biblioteca para colocar pausa em algumas strings.

while True:
    
    print(Fore.YELLOW + "\nINICIANDO A CALCULADORA...\n")
    #sleep(3)#Uma "brincadeira" para adicionar um tempinho fingindo que a calculadora está iniciando.

    print(Fore.WHITE + "===" * 11)
    print("SEJA BEM VINDO(A) A " + Fore.RED + Style.BRIGHT + "CALCULADORA!" + Style.RESET_ALL + Fore.WHITE)
    print("===" * 11)

#faz o design da calculadora, imprimindo uma mensagem de boas-vindas e separand em  linhas.
 
    print("Escolha a operação que deseja utilizar:\n")
    print(Fore.GREEN + Style.BRIGHT + "1.Soma(+)\n" + Style.RESET_ALL)
    print(Fore.YELLOW + Style.BRIGHT + "2.Subtração(-)\n" + Style.RESET_ALL)
    print(Fore.LIGHTCYAN_EX + Style.BRIGHT + "3.Multiplicação(*)\n" + Style.RESET_ALL)
    print(Fore.MAGENTA +  Style.BRIGHT + "4.Divisão(/)\n" + Style.RESET_ALL)
    print(Fore.BLUE + Style.BRIGHT + "5.Potência(**)\n" + Style.RESET_ALL)
    print(Fore.RED + Style.BRIGHT + "6.Sair(X)\n" + Style.RESET_ALL)

    oper = input(Fore.WHITE + "Digite a operação que você deseja utilizar:"+ Fore.RED + Style.BRIGHT + " ")
    if oper == "6":
        print(Fore.LIGHTMAGENTA_EX + "Reiniciando...\n")
        sleep(2)
        continue #verifica se a operação escolhida é "6" (Sair). Se for, imprime uma mensagem de reinício, "conta" 2 segundos e reinicia o loop.

#solicita ao usuário que escolha uma operação e, se a opção for "6", imprime uma mensagem de despedida e encerra o programa. Caso contrário, continua solicitando os números para realizar a operação escolhida.

    num1 = float(input(Fore.WHITE + "Digite o primeiro número:" + Fore.RED + Style.BRIGHT + " "))
    num2 = float(input(Fore.WHITE + "Digite o segundo número:" + Fore.RED + Style.BRIGHT + " " ))

    print(Fore.YELLOW + "\nCalculando...\n" + Fore.WHITE + "")
    sleep(2) #adiciona uma pausa de 1 segundo para simular o processo de cálculo, tornando a experiência do usuário mais realista.

#verifica qual operação o usuário escolheu e faz o cálculo de acordo com a operação escolhida. O loop continua até o usuário escolher a opção de sair (6).
    if oper == "4" or oper == "/":
        if num2 != 0:
            print("O resultado da divisão é: " + Fore.MAGENTA + f"{num1 / num2}" + Fore.WHITE + "\n")
        else:
            print(Fore.RED + Style.BRIGHT + "[ERRO]" + Style.RESET_ALL + Fore.WHITE + " Não é possível dividir por zero.\n")
#verifica se o usuário escolheu a operação de divisão. Caso o usuário tenha escolhido divisão com 0 com um dos números, o programa avisa com uma mensagem de erro. Caso use números diferntes de zero, o programa faz o cálculo normalmente.
    if oper == "1" or oper == "+":
        resul = num1 + num2
        print("O resultado da soma é: " + Fore.GREEN + f"{resul}" + Fore.WHITE + "\n")
    
    elif oper == "2" or oper == "-":
        print("O resultado da subtração é: " + Fore.RED + f"{num1 - num2}" + Fore.WHITE + "\n")
    
    elif oper == "3" or oper == "*":
        print("O resultado da multiplicação é: " + Fore.BLUE + f"{num1 * num2}" + Fore.WHITE + "\n")
    
    elif oper == "5" or oper == "**":
        print("O resultado da potência é:" + Fore.CYAN + f"{num1 ** num2}" + Fore.WHITE + "\n")
